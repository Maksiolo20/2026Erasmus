#show results
import cv2
import matplotlib.pyplot as plt
base, ext = os.path.splitext(img_name)

img_orig = cv2.cvtColor(cv2.imread(f'/content/Real-ESRGAN/{img_name}'), cv2.COLOR_BGR2RGB)
img_x2 = cv2.cvtColor(cv2.imread(f'results_x2/{base}_out{ext}'), cv2.COLOR_BGR2RGB)
img_x4 = cv2.cvtColor(cv2.imread(f'results_x4/{base}_out{ext}'), cv2.COLOR_BGR2RGB)

fig, ax = plt.subplots(1, 3, figsize=(18, 6))
ax[0].imshow(img_orig); ax[0].set_title(f"Original ({img_orig.shape[1]}x{img_orig.shape[0]})"); ax[0].axis('off')
ax[1].imshow(img_x2);   ax[1].set_title(f"Real-ESRGAN x2 ({img_x2.shape[1]}x{img_x2.shape[0]})");   ax[1].axis('off')
ax[2].imshow(img_x4);   ax[2].set_title(f"Real-ESRGAN x4 ({img_x4.shape[1]}x{img_x4.shape[0]})");   ax[2].axis('off')
plt.tight_layout()
plt.show()
