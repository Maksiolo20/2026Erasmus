#patch previous downloads
import os
import re
import site
deg_file = '/usr/local/lib/python3.12/dist-packages/basicsr/data/degradations.py'
try:
    with open(deg_file, 'r') as f: content = f.read()
    content = re.sub(r"from torchvision.transforms.functional_tensor import rgb_to_grayscale",
                     r"import torchvision.transforms.functional as F\ndef rgb_to_grayscale(img):\n    return F.rgb_to_grayscale(img)", content)
    with open(deg_file, 'w') as f: f.write(content)
except FileNotFoundError: pass

